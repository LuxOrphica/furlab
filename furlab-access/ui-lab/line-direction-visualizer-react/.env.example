# React UI version (shown in sidebar)
VITE_APP_VERSION=2.0.33-line

# Optional explicit API base URL.
# Example: API origin of the running backend.
# If empty, UI falls back to the current host on the default API port.
VITE_API_BASE_URL=

# Optional explicit frontend host for development HMR.
VITE_HMR_HOST=

# Optional public origin for development server URLs.
VITE_PUBLIC_ORIGIN=
