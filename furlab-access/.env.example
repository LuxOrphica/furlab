# Server bind
UI_LAB_HOST=127.0.0.1
UI_LAB_PORT=5500

# Access DB path (optional, absolute path)
# FURLAB_DB_PATH=F:\FURLAB\dev\furlab-access\БД\Furlab 1.accdb

# Write API protection (recommended in any shared environment)
FURLAB_API_KEY=change-me

# Allowed CORS origins (comma-separated)
UI_LAB_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5500,http://localhost:5500

# Cache TTLs (ms)
FURLAB_DICTS_TTL_MS=3600000
FURLAB_REGISTRY_TTL_MS=300000
FURLAB_HISTORY_TTL_MS=60000
FURLAB_PIECE_TTL_MS=30000
FURLAB_CONTOUR_TTL_MS=300000

# Reader/copy timings (ms)
FURLAB_REGISTRY_TIMEOUT_MS=7000
FURLAB_PIECE_TIMEOUT_MS=15000
FURLAB_REGISTRY_MIRROR_MAX_AGE_MS=30000
