<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 {{VIEW_W}} {{VIEW_H}}' width='100%' height='100%' preserveAspectRatio='xMidYMid meet'>
  <style>
    .t-grid-minor { stroke: #e1e5ea; stroke-width: 0.8; }
    .t-axis { stroke: #1f2328; stroke-width: 1.25; }
    .t-axis-tick { stroke: #1f2328; stroke-width: 0.9; }
    .t-axis-text { fill: #1f2328; font-size: 10px; }
    .t-box-line { stroke: #d3d9e1; stroke-width: 0.85; }
    .t-contour { fill: none; stroke: #1f2328; stroke-width: 2; }
    .t-panel { fill: #fdfdfd; stroke: #2b3138; stroke-width: 1; }
    .t-panel-title { fill: #1f2328; font-size: 12px; font-family: Consolas, "Courier New", monospace; }
    .t-panel-rule { stroke: #c8ccd2; stroke-width: 1; }
    .t-panel-text { fill: #1f2328; font-size: 11px; font-family: Consolas, "Courier New", monospace; }
    .t-legend-text { fill: #1f2328; font-size: 10px; font-family: Consolas, "Courier New", monospace; }
    .arrow-scan { stroke: #5a5a5a; stroke-width: 2; fill: none; }
    .arrow-scan-dot { fill: #5a5a5a; }
    .arrow-norm { stroke: #111111; stroke-width: 3; fill: none; }
    .arrow-norm-dot { fill: #111111; }
  </style>
  <rect x='0' y='0' width='{{VIEW_W}}' height='{{VIEW_H}}' fill='#f1f3f6' stroke='#c9ced6'/>
  <rect x='{{PLOT_X}}' y='{{PLOT_Y}}' width='{{PLOT_W}}' height='{{PLOT_H}}' fill='#ffffff' stroke='#c2c8d0' stroke-width='1'/>
  {{LAYERS}}
  <polygon class='t-contour' points='{{PTS}}' fill='none' stroke='#1f2328' stroke-width='2'/>
  {{IN_ARROW}}
  <rect class='t-panel' x='{{PANEL_X}}' y='{{PANEL_Y}}' width='{{PANEL_W}}' height='{{PANEL_H}}' fill='#fdfdfd' stroke='#2b3138' stroke-width='1'/>
  <text class='t-panel-title' x='{{INFO_X}}' y='{{TITLE_Y}}' fill='#1f2328' font-size='12' font-family='Consolas, Courier New, monospace'>Contour Summary</text>
  <line class='t-panel-rule' x1='{{INFO_X}}' y1='{{TITLE_RULE_Y}}' x2='{{INFO_X2}}' y2='{{TITLE_RULE_Y}}' stroke='#c8ccd2' stroke-width='1'/>
  <g class='t-panel-text' fill='#1f2328' font-size='11' font-family='Consolas, Courier New, monospace'>
    <text x='{{INFO_X}}' y='{{INFO_Y0}}'>{{INFO_LINE_0}}</text>
    <text x='{{INFO_X}}' y='{{INFO_Y1}}'>{{INFO_LINE_1}}</text>
    <text x='{{INFO_X}}' y='{{INFO_Y2}}'>{{INFO_LINE_2}}</text>
    <text x='{{INFO_X}}' y='{{INFO_Y3}}'>{{INFO_LINE_3}}</text>
    <text x='{{INFO_X}}' y='{{INFO_Y4}}'>{{INFO_LINE_4}}</text>
    <text x='{{INFO_X}}' y='{{INFO_Y5}}'>{{INFO_LINE_5}}</text>
    <text x='{{INFO_X}}' y='{{INFO_Y6}}'>{{INFO_LINE_6}}</text>
    <text x='{{INFO_X}}' y='{{INFO_Y7}}'>{{INFO_LINE_7}}</text>
    <text x='{{INFO_X}}' y='{{INFO_Y8}}'>{{INFO_LINE_8}}</text>
  </g>
  <line class='t-panel-rule' x1='{{INFO_X}}' y1='{{LEGEND_RULE_Y}}' x2='{{INFO_X2}}' y2='{{LEGEND_RULE_Y}}' stroke='#c8ccd2' stroke-width='1'/>
  {{LEGEND_SCAN_ARROW}}
  <text class='t-legend-text' x='{{LEGEND_TX}}' y='{{LEGEND_SCAN_TY}}' fill='#1f2328' font-size='10' font-family='Consolas, Courier New, monospace'>scan direction</text>
  {{LEGEND_NORM_ARROW}}
  {{LEGEND_NORM_TEXT}}
</svg>
